# Dev deployment environment variables
# Loaded when running `pnpm build --mode dev`
# Used for PR preview deployments

# Show dev tools (SMS Log, etc.) in dev deployments
VITE_SHOW_DEV_TOOLS=true

# Use dev auth (bypasses MSAL, always authenticated as dev identity)
VITE_USE_DEV_AUTH=true
VITE_DEV_IDENTITY_ID=dev-admin-oid
