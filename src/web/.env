# Common environment variables for all environments
# Variables prefixed with VITE_ are exposed to the client-side code

# API URL is set at build time by CI/CD (see .github/workflows/deploy-web.yml)
# Locally, it defaults to the local API server
VITE_API_URL=http://localhost:5221

# Azure Entra ID / MSAL configuration (set in environment-specific .env files or CI/CD)
VITE_ENTRA_AUTHORITY=
VITE_ENTRA_CLIENT_ID=
VITE_API_SCOPE=
