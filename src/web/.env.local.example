# Local environment overrides (NOT committed to git)
# Copy this file to .env.local and customize as needed

# Uncomment to override the API URL for local development
# VITE_API_URL=http://localhost:5000

# Uncomment to show dev tools in production builds (for testing)
# VITE_SHOW_DEV_TOOLS=true

# ---------------------------------------------------------------
# Dev auth bypass — local QA testing without real Entra login
# ---------------------------------------------------------------
# Create .env.development.local (gitignored via *.local) with:
#
#   VITE_USE_DEV_AUTH=true
#   VITE_DEV_IDENTITY_ID=dev-admin-oid
#
# VITE_USE_DEV_AUTH=true skips the MSAL login flow and injects a
# synthetic identity using VITE_DEV_IDENTITY_ID as the object ID.
# This file is loaded automatically by Vite alongside .env.development
# and is never committed to git.
